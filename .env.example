# Copy to .env.local (for dev) or set as env vars on Cloud Run.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Where the SQLite file lives. Cloud Run has an ephemeral /tmp which is fine
# for a demo — the DB will be re-seeded on each cold start.
SULTAN_DB_PATH=/tmp/sultan.db

# Store location (Sultan Market, Tampa, FL)
SULTAN_STORE_LAT=28.0395
SULTAN_STORE_LNG=-82.4572
